# Copy these values into Supabase Edge Function secrets. Never expose this file
# to the browser and never commit real values.

# Direct Stripe account
STRIPE_SANDBOX_SECRET_KEY=sk_test_...
STRIPE_SANDBOX_WEBHOOK_SECRET=whsec_...
# Add these only when production billing is ready.
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=

# Direct email account (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=CareWeaveHQ <noreply@notify.careweavehq.com>
EMAIL_SITE_NAME=CareWeaveHQ
EMAIL_SENDER_DOMAIN=notify.careweavehq.com

# OpenAI-compatible AI provider
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_VISION_MODEL=gpt-4.1

# Direct Twilio account
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Existing Lovable credentials may remain during transition. Direct credentials
# above take priority and these can be removed after cutover is verified.
LOVABLE_API_KEY=
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
TWILIO_API_KEY=
